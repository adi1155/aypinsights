APP_NAME="AYP Insights"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Application database (MariaDB recommended for production)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ayp_insights
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database
CACHE_STORE=database

# Redis (optional — set CACHE_STORE=redis for production)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="insights@ayperp.net"
MAIL_FROM_NAME="${APP_NAME}"

# ERPNext v15 REST API — https://gmp.ayperp.net
ERPNEXT_URL=https://gmp.ayperp.net
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_TIMEOUT=60
ERPNEXT_USE_DUMMY_DATA=false
ERPNEXT_DEFAULT_COMPANY="GMP Foods (Pvt.) Ltd"
ERPNEXT_DEFAULT_CURRENCY=PKR
DASHBOARD_CACHE_TTL=300

# Optional read-only ERPNext MariaDB (set ERPNEXT_USE_DUMMY_DATA=false when configured)
ERPNEXT_DB_HOST=127.0.0.1
ERPNEXT_DB_PORT=3306
ERPNEXT_DB_DATABASE=erpnext
ERPNEXT_DB_USERNAME=readonly_user
ERPNEXT_DB_PASSWORD=

# WhatsApp Business API webhook (optional)
WHATSAPP_WEBHOOK_URL=

VITE_APP_NAME="${APP_NAME}"
